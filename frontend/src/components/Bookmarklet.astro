---
import { Icon } from "@astrojs/starlight/components";
---

<section class="bookmarklet-panel" aria-label="Quick convert bookmark">
  <h3>Quick convert</h3>
  <p>Drag this bookmark once, then use it on any page you want to convert.</p>
  <div class="bookmarklet-actions">
    <a id="bookmarklet" class="bookmarklet-link" href="#"><Icon name="rss" /> Convert to RSS</a>
  </div>
  <p class="bookmarklet-help">After saving it, visit a site and click the bookmark.</p>
</section>

<style>
  .bookmarklet-panel {
    margin-top: 1.25rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.6rem;
    background: color-mix(in srgb, var(--sl-color-bg) 88%, var(--sl-color-bg-nav) 12%);
    padding: 1rem 1.25rem;
  }

  .bookmarklet-panel h3 {
    margin: 0;
    font-size: 1rem;
    color: var(--sl-color-text);
  }

  .bookmarklet-panel p {
    margin: 0.35rem 0 0;
    color: var(--sl-color-text-accent);
    font-size: 0.9rem;
  }

  .bookmarklet-actions {
    margin-top: 0.85rem;
  }

  .bookmarklet-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 0.8rem;
    border: 1px dashed var(--sl-color-hairline);
    border-radius: 0.5rem;
    color: var(--sl-color-text);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    background: transparent;
  }

  .bookmarklet-link:hover {
    border-color: var(--sl-color-accent);
    text-decoration: none;
  }

  .bookmarklet-help {
    margin-top: 0.65rem;
    font-size: 0.82rem;
  }
</style>

<script>
  // Bookmarklet functionality
  function initBookmarklet() {
    const bookmarklet = document.getElementById("bookmarklet") as HTMLAnchorElement;
    if (bookmarklet) {
      // Use the current origin (should be the Astro dev server)
      const baseUrl = new URL(window.location.origin);
      baseUrl.pathname = "/";
      baseUrl.search = "?url=";
      bookmarklet.href = `javascript:window.location.href='${baseUrl.toString()}'+encodeURIComponent(window.location.href);`;
    }
  }

  // Initialize on page load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initBookmarklet);
  } else {
    initBookmarklet();
  }
</script>
