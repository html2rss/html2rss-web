---
import { Icon } from "@astrojs/starlight/components";
---

<details class="bookmarklet-inline" aria-label="Bookmarklet utility">
  <summary>Advanced: bookmarklet</summary>
  <p>
    Drag this to your bookmarks bar:
    <a id="bookmarklet" class="bookmarklet-link" href="#"><Icon name="rss" /> Convert to RSS</a>
  </p>
</details>

<style>
  .bookmarklet-inline {
    margin-top: 0.35rem;
    padding: 0.2rem 0.1rem;
    color: var(--sl-color-text-accent);
  }

  .bookmarklet-inline summary {
    cursor: pointer;
    list-style: none;
    margin: 0;
    font-size: 0.8rem;
  }

  .bookmarklet-inline summary::-webkit-details-marker {
    display: none;
  }

  .bookmarklet-inline p {
    margin: 0.45rem 0 0;
    font-size: 0.8rem;
    color: var(--sl-color-text-accent);
  }

  .bookmarklet-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.2rem 0.45rem;
    margin-left: 0.35rem;
    border: 1px dashed var(--sl-color-hairline);
    border-radius: 0.5rem;
    color: var(--sl-color-text-accent);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.82rem;
    background: transparent;
  }

  .bookmarklet-link:hover {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-text);
    text-decoration: none;
  }
</style>

<script>
  // Bookmarklet functionality
  function initBookmarklet() {
    const bookmarklet = document.getElementById("bookmarklet") as HTMLAnchorElement;
    if (bookmarklet) {
      // Use the current origin (should be the Astro dev server)
      const baseUrl = new URL(window.location.origin);
      baseUrl.pathname = "/";
      baseUrl.search = "?url=";
      bookmarklet.href = `javascript:window.location.href='${baseUrl.toString()}'+encodeURIComponent(window.location.href);`;
    }
  }

  // Initialize on page load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initBookmarklet);
  } else {
    initBookmarklet();
  }
</script>
